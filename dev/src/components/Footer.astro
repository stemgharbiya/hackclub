---
import Icon from './Icon.astro';
---

<footer class="mt-16 border-t border-slate-200 dark:border-slate-800">
  <div class="container-shell flex flex-col gap-4 py-8 text-sm text-slate-600 dark:text-slate-300 md:flex-row md:items-center md:justify-between">
    <p>© {new Date().getFullYear()} Gharbiya STEM Hack Club. Built with 💖.</p>
    <code class="text-slate-500 dark:text-slate-400">Gharbiya STEM Hack Club is fiscally sponsored by The Hack Foundation (d.b.a. Hack Club), a 501(c)(3) nonprofit (EIN: 81-2908499).</code>
    <div class="flex items-center gap-3">
      <a href="https://github.com/hack-club-gh" target="_blank" rel="noreferrer" class="inline-flex items-center justify-center w-6 h-6 hover:text-slate-900 dark:hover:text-slate-100" title="GitHub">
        <Icon name="github" class="w-5 h-5" />
      </a>
      <a href="https://www.instagram.com/gh_hackclub/" target="_blank" rel="noreferrer" class="inline-flex items-center justify-center w-6 h-6 hover:text-slate-900 dark:hover:text-slate-100" title="Instagram">
        <Icon name="instagram" class="w-5 h-5" />
      </a>
    </div>
  </div>
</footer>
