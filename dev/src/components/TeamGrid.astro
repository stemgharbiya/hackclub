---
import type { CollectionEntry } from 'astro:content';

interface Props {
  team: CollectionEntry<'team'>[];
}

const { team } = Astro.props as Props;
---

<div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
  {
    team.map(({ data, body }) => (
      <article class="surface p-4">
        <img
          src={data.photo.src}
          alt={data.name}
          class="mb-4 h-56 w-full rounded-xl object-cover"
          loading="lazy"
        />
        <h3 class="text-lg font-semibold text-slate-900 dark:text-slate-100">{data.name}</h3>
        <p class="text-sm font-medium text-blue-600 dark:text-blue-400">{data.role}</p>
        <p class="mt-1 text-xs uppercase tracking-wide text-slate-500 dark:text-slate-400">{data.committee}</p>
        <p class="mt-3 text-sm text-slate-600 dark:text-slate-300">{body}</p>
      </article>
    ))
  }
</div>
