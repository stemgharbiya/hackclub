---
import ThemeToggle from './ThemeToggle.astro';

interface Props {
  currentPath: string;
}

const { currentPath } = Astro.props as Props;

const links = [
  { href: '/', label: 'Home' },
  { href: '/about', label: 'About' },
  { href: '/bootcamps', label: 'Bootcamps' },
  { href: '/events', label: 'Events' },
  { href: '/workshops', label: 'Workshops' },
  { href: '/team', label: 'Team' },
  { href: '/contact', label: 'Contact' }
];
---

<header class="sticky top-0 z-40 border-b border-slate-200/80 bg-white/90 backdrop-blur dark:border-slate-800/80 dark:bg-slate-950/90">
  <div class="container flex items-center justify-between gap-4 py-4">
    <a href="/" class="flex items-center gap-2 text-base font-bold tracking-tight text-slate-900 dark:text-white hover:opacity-80 transition-colors">
      <img src="https://assets.hackclub.com/flag-standalone.svg" alt="Hack Club" class="w-8 h-8" />
      <span>Gharbiya STEM</span>
    </a>
    <nav class="hidden items-center gap-2 lg:flex" aria-label="Main navigation">
      {
        links.map((link) => (
          <a
            href={link.href}
            class:list={[
              'rounded-lg px-3 py-2 text-sm font-medium transition-colors',
              currentPath === link.href
                ? 'text-white dark:text-slate-900'
                : 'text-slate-600 hover:bg-slate-100 hover:text-slate-900 dark:text-slate-300 dark:hover:bg-slate-800 dark:hover:text-white'
            ]}
            style={currentPath === link.href ? 'background: var(--accent)' : ''}
          >
            {link.label}
          </a>
        ))
      }
    </nav>
    <div class="flex items-center gap-2">
      <button
        type="button"
        class="inline-flex items-center justify-center rounded-xl border border-slate-300 px-3 py-2 text-sm font-medium text-slate-700 transition-colors hover:bg-slate-100 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-[var(--accent)] focus-visible:ring-offset-2 dark:border-slate-700 dark:text-slate-200 dark:hover:bg-slate-800 dark:focus-visible:ring-offset-slate-950 lg:hidden"
        data-menu-toggle
        aria-expanded="false"
        aria-controls="mobile-menu-overlay"
        aria-label="Toggle navigation menu"
      >
        <span class="sr-only">Toggle navigation menu</span>
        <svg data-menu-open-icon xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5" />
        </svg>
        <svg data-menu-close-icon xmlns="http://www.w3.org/2000/svg" class="hidden h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M6 18 18 6M6 6l12 12" />
        </svg>
      </button>
      <ThemeToggle />
    </div>
  </div>
</header>

<div
  id="mobile-menu-overlay"
  data-mobile-menu-overlay
  class="pointer-events-none invisible fixed inset-0 z-[60] opacity-0 transition-opacity duration-200 lg:hidden"
  aria-hidden="true"
>
  <button
    type="button"
    data-menu-backdrop
    class="absolute inset-0 border-0 bg-slate-950/70"
    aria-label="Close navigation menu"
  ></button>

  <div
    data-mobile-menu-sheet
    class="absolute inset-0 rounded-none translate-y-2 overflow-y-auto bg-white px-6 pb-8 pt-24 transition-transform duration-200 dark:bg-slate-950"
  >
    <div class="mx-auto flex w-full max-w-6xl items-center justify-end">
      <button
        type="button"
        data-menu-close
        class="inline-flex items-center justify-center rounded-xl border border-slate-300 px-3 py-2 text-sm font-medium text-slate-700 transition-colors hover:bg-slate-100 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-[var(--accent)] focus-visible:ring-offset-2 dark:border-slate-700 dark:text-slate-200 dark:hover:bg-slate-800 dark:focus-visible:ring-offset-slate-950"
        aria-label="Close navigation menu"
      >
        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M6 18 18 6M6 6l12 12" />
        </svg>
      </button>
    </div>

    <nav class="mx-auto mt-4 flex w-full max-w-6xl flex-col gap-3" aria-label="Mobile navigation">
      {
        links.map((link) => (
          <a
            href={link.href}
            data-menu-link
            class:list={[
              'rounded-xl px-4 py-3 text-base font-semibold transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-[var(--accent)] focus-visible:ring-offset-2 dark:focus-visible:ring-offset-slate-950',
              currentPath === link.href
                ? 'text-white dark:text-slate-950'
                : 'bg-slate-100 text-slate-700 hover:bg-slate-200 dark:bg-slate-900 dark:text-slate-200 dark:hover:bg-slate-800'
            ]}
            style={currentPath === link.href ? 'background: var(--accent)' : ''}
          >
            {link.label}
          </a>
        ))
      }
    </nav>
  </div>
</div>

<script is:inline>
  const menuToggle = document.querySelector('[data-menu-toggle]');
  const menuOverlay = document.querySelector('[data-mobile-menu-overlay]');
  const menuSheet = document.querySelector('[data-mobile-menu-sheet]');
  const backdrop = document.querySelector('[data-menu-backdrop]');
  const menuClose = document.querySelector('[data-menu-close]');
  const openIcon = document.querySelector('[data-menu-open-icon]');
  const closeIcon = document.querySelector('[data-menu-close-icon]');
  const menuLinks = Array.from(document.querySelectorAll('[data-menu-link]'));
  const desktopMediaQuery = window.matchMedia('(min-width: 1024px)');

  if (menuToggle && menuOverlay && menuSheet && backdrop) {
    let isOpen = false;

    const syncIcons = () => {
      if (openIcon && closeIcon) {
        openIcon.classList.toggle('hidden', isOpen);
        closeIcon.classList.toggle('hidden', !isOpen);
      }
    };

    const openMenu = () => {
      if (isOpen) return;
      isOpen = true;
      menuToggle.setAttribute('aria-expanded', 'true');
      menuOverlay.classList.remove('pointer-events-none', 'invisible', 'opacity-0');
      menuOverlay.classList.add('pointer-events-auto', 'visible', 'opacity-100');
      menuOverlay.setAttribute('aria-hidden', 'false');
      menuSheet.classList.remove('translate-y-2');
      menuSheet.classList.add('translate-y-0');
      document.body.style.overflow = 'hidden';
      syncIcons();
    };

    const closeMenu = () => {
      if (!isOpen) return;
      isOpen = false;
      menuToggle.setAttribute('aria-expanded', 'false');
      menuOverlay.classList.add('pointer-events-none', 'invisible', 'opacity-0');
      menuOverlay.classList.remove('pointer-events-auto', 'visible', 'opacity-100');
      menuOverlay.setAttribute('aria-hidden', 'true');
      menuSheet.classList.add('translate-y-2');
      menuSheet.classList.remove('translate-y-0');
      document.body.style.overflow = '';
      syncIcons();
    };

    menuToggle.addEventListener('click', () => {
      if (isOpen) {
        closeMenu();
      } else {
        openMenu();
      }
    });

    backdrop.addEventListener('click', closeMenu);
    if (menuClose) {
      menuClose.addEventListener('click', closeMenu);
    }
    menuLinks.forEach((link) => link.addEventListener('click', closeMenu));

    document.addEventListener('keydown', (event) => {
      if (event.key === 'Escape') {
        closeMenu();
      }
    });

    const closeOnDesktop = (event) => {
      if (event.matches) {
        closeMenu();
      }
    };

    if (typeof desktopMediaQuery.addEventListener === 'function') {
      desktopMediaQuery.addEventListener('change', closeOnDesktop);
    } else {
      desktopMediaQuery.addListener(closeOnDesktop);
    }
  }
</script>
