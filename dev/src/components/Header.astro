---
import ThemeToggle from './ThemeToggle.astro';

interface Props {
  currentPath: string;
}

const { currentPath } = Astro.props as Props;

const links = [
  { href: '/', label: 'Home' },
  { href: '/about', label: 'About' },
  { href: '/bootcamps', label: 'Bootcamps' },
  { href: '/events', label: 'Events' },
  { href: '/workshops', label: 'Workshops' },
  { href: '/team', label: 'Team' },
  { href: '/contact', label: 'Contact' }
];
---

<header class="sticky top-0 z-40 border-b border-slate-200/80 bg-white/90 backdrop-blur dark:border-slate-800/80 dark:bg-slate-950/90">
  <div class="container-shell flex items-center justify-between gap-4 py-4">
    <a href="/" class="flex items-center gap-2 text-base font-bold tracking-tight text-slate-900 dark:text-white hover:opacity-80 transition-colors">
      <img src="https://assets.hackclub.com/flag-standalone.svg" alt="Hack Club" class="w-8 h-8" />
      <span>Gharbiya STEM</span>
    </a>
    <nav class="hidden items-center gap-2 md:flex" aria-label="Main navigation">
      {
        links.map((link) => (
          <a
            href={link.href}
            class:list={[
              'rounded-lg px-3 py-2 text-sm font-medium transition-colors',
              currentPath === link.href
                ? 'text-white dark:text-slate-900'
                : 'text-slate-600 hover:bg-slate-100 hover:text-slate-900 dark:text-slate-300 dark:hover:bg-slate-800 dark:hover:text-white'
            ]}
            style={currentPath === link.href ? 'background: var(--accent)' : ''}
          >
            {link.label}
          </a>
        ))
      }
    </nav>
    <div class="flex items-center gap-2">
      <ThemeToggle />
    </div>
  </div>
  <div class="container-shell md:hidden">
    <nav class="flex flex-wrap gap-2 pb-4" aria-label="Mobile navigation">
      {
        links.map((link) => (
          <a
            href={link.href}
            class:list={[
              'rounded-lg px-3 py-2 text-sm font-medium',
              currentPath === link.href
                ? 'bg-slate-900 text-white dark:bg-slate-100 dark:text-slate-900'
                : 'bg-slate-100 text-slate-700 dark:bg-slate-800 dark:text-slate-200'
            ]}
          >
            {link.label}
          </a>
        ))
      }
    </nav>
  </div>
</header>
