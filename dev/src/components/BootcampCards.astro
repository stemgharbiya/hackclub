---
import type { CollectionEntry } from 'astro:content';

interface Props {
  bootcamps: CollectionEntry<'bootcamps'>[];
}

const { bootcamps } = Astro.props as Props;
---

<div class="grid gap-6 md:grid-cols-2">
  {
    bootcamps.map(({ data, body }) => (
      <article class="surface">
        <h3 class="text-xl font-semibold text-slate-900 dark:text-white">{data.title}</h3>
        <p class="mt-1 text-sm font-medium" style="color: var(--accent)">{data.period} · {data.level}</p>
        <p class="mt-4 text-sm text-slate-600 dark:text-slate-300">{body}</p>
        <p class="mt-4 text-sm font-medium text-slate-700 dark:text-slate-200">Track focus: {data.mentorTrack}</p>
      </article>
    ))
  }
</div>
