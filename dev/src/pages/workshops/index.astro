---
import { getCollection } from 'astro:content';
import Icon from '../../components/Icon.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import theme from '@hackclub/theme';

const workshops = (await getCollection('workshops')).sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
const featuredWorkshop = workshops[0]; // Most recent workshop
---

<BaseLayout
  title="Workshops | Gharbiya STEM Hack Club"
  description="Hack Club workshops and practical learning sessions delivered by the club."
  currentPath="/workshops"
>
  <!-- Hero Section -->
  <section class="card mb-12">
    <p class="text-sm font-semibold uppercase tracking-wide" style="color: var(--color-purple)">// LEARN SOMETHING NEW</p>
    <h1 class="mt-3 text-4xl font-bold tracking-tight text-slate-900 dark:text-white sm:text-5xl" style={`background-image: ${theme.util.gx('purple', 'blue')}; -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;`}>Learn something new every week.</h1>
    <p class="mt-4 max-w-3xl text-lg text-slate-600 dark:text-slate-300">
      We actively join Hack Club workshops and transform those sessions into practical project outcomes. 
      From web apps to creative coding, every workshop is a chance to build something real.
    </p>
    <div class="mt-6 flex flex-wrap gap-3">
      <a class="btn cta" href="#all-workshops">Browse workshops</a>
      <a class="btn outline" href="https://jams.hackclub.com" target="_blank" rel="noreferrer">Explore Hack Club Jams</a>
    </div>
  </section>

  <!-- Featured Workshop Spotlight -->
  <section class="mb-12">
    <h2 class="mb-6 text-3xl font-bold text-slate-900 dark:text-white">Latest Workshop</h2>
    <div class="card gradient-purple-blue">
      <div class="grid gap-6 md:grid-cols-3">
        <div class="md:col-span-2">
          <p class="text-xs uppercase tracking-wide text-slate-500 dark:text-slate-400">
            {featuredWorkshop.data.date.toLocaleDateString('en-GB')} · {featuredWorkshop.data.provider}
          </p>
          <h3 class="mt-2 text-2xl font-bold text-slate-900 dark:text-white">{featuredWorkshop.data.title}</h3>
          <p class="mt-3 text-slate-600 dark:text-slate-300">{featuredWorkshop.body}</p>
          <p class="mt-4 text-sm font-medium text-slate-700 dark:text-slate-200">
            <strong>Outcome:</strong> {featuredWorkshop.data.outcome}
          </p>
          <div class="mt-4">
            <a class="btn outline" href={`/workshops/${featuredWorkshop.id.replace(/\.md$/, '')}/`}>
              Read details →
            </a>
          </div>
        </div>
        {(featuredWorkshop.data.approvedSubmissions || featuredWorkshop.data.participations) && (
          <div class="flex items-center">
            <div class="space-y-3">
              {featuredWorkshop.data.approvedSubmissions && (
                <div class="rounded-xl bg-slate-100 p-4 dark:bg-slate-800">
                  <p class="text-2xl font-bold text-slate-900 dark:text-white">{featuredWorkshop.data.approvedSubmissions}</p>
                  <p class="text-xs text-slate-600 dark:text-slate-400">Submissions</p>
                </div>
              )}
              {featuredWorkshop.data.participations && (
                <div class="rounded-xl bg-slate-100 p-4 dark:bg-slate-800">
                  <p class="text-2xl font-bold text-slate-900 dark:text-white">{featuredWorkshop.data.participations}+</p>
                  <p class="text-xs text-slate-600 dark:text-slate-400">Participants</p>
                </div>
              )}
            </div>
          </div>
        )}
      </div>
    </div>
  </section>

  <!-- All Workshops Grid -->
  <section class="mb-12" id="all-workshops">
    <h2 class="mb-6 text-3xl font-bold text-slate-900 dark:text-white">All Workshops</h2>
    <div class="grid gap-6 md:grid-cols-2">
      {
        workshops.map(({ id, data, body }) => (
          <article class="card">
            <p class="text-xs uppercase tracking-wide text-slate-500 dark:text-slate-400">{data.date.toLocaleDateString('en-GB')} · {data.provider}</p>
            <h2 class="mt-2 text-xl font-semibold text-slate-900 dark:text-white">{data.title}</h2>
            <p class="mt-3 text-sm text-slate-600 dark:text-slate-300">{body}</p>
            <p class="mt-4 text-sm font-medium text-slate-700 dark:text-slate-200">{data.outcome}</p>
            {
              (data.approvedSubmissions || data.participations || data.budgetSpent) && (
                <div class="mt-3 space-y-1 text-xs text-slate-600 dark:text-slate-400">
                  {data.approvedSubmissions && <p class="flex items-center gap-1.5"><Icon name="check-circle" class="w-4 h-4 flex-shrink-0" /> {data.approvedSubmissions} approved submissions</p>}
                  {data.participations && <p class="flex items-center gap-1.5"><Icon name="check-circle" class="w-4 h-4 flex-shrink-0" /> {data.participations}+ participations</p>}
                  {data.budgetSpent && <p class="flex items-center gap-1.5"><Icon name="wallet" class="w-4 h-4 flex-shrink-0" /> {data.budgetSpent}</p>}
                  {data.rewardsMarketing && <p class="flex items-center gap-1.5"><Icon name="gift" class="w-4 h-4 flex-shrink-0" /> {data.rewardsMarketing}</p>}
                  {data.note && <p>{data.note}</p>}
                </div>
              )
            }
            <div class="mt-4 flex flex-wrap items-center gap-4">
              <a class="inline-flex text-sm font-semibold hover:opacity-80 transition-opacity" style="color: var(--accent)" href={`/workshops/${id.replace(/\.md$/, '')}/`}>
                Read details
              </a>
              {
                data.links && data.links.length > 0 && (
                  <>
                    {data.links.map((link) => (
                      <a class="inline-flex text-sm font-semibold hover:opacity-80 transition-opacity" style="color: var(--accent)" href={link.url} target="_blank" rel="noreferrer">
                        {link.label}
                      </a>
                    ))}
                  </>
                )
              }
            </div>
          </article>
        ))
      }
    </div>
  </section>

  <!-- Technologies Covered -->
  <section class="mb-12">
    <h2 class="mb-6 text-3xl font-bold text-slate-900 dark:text-white">What You'll Build</h2>
    <div class="card">
      <div class="grid gap-4 sm:grid-cols-2 md:grid-cols-3">
        <div class="flex items-start gap-3">
          <span class="text-2xl">🌐</span>
          <div>
            <h3 class="font-semibold text-slate-900 dark:text-white">Web Apps</h3>
            <p class="text-sm text-slate-600 dark:text-slate-300">Interactive websites and applications</p>
          </div>
        </div>
        <div class="flex items-start gap-3">
          <span class="text-2xl">🎨</span>
          <div>
            <h3 class="font-semibold text-slate-900 dark:text-white">Creative Coding</h3>
            <p class="text-sm text-slate-600 dark:text-slate-300">Generative art and animations</p>
          </div>
        </div>
        <div class="flex items-start gap-3">
          <span class="text-2xl">🎮</span>
          <div>
            <h3 class="font-semibold text-slate-900 dark:text-white">Games</h3>
            <p class="text-sm text-slate-600 dark:text-slate-300">Browser-based interactive games</p>
          </div>
        </div>
        <div class="flex items-start gap-3">
          <span class="text-2xl">🤖</span>
          <div>
            <h3 class="font-semibold text-slate-900 dark:text-white">Bots & Automation</h3>
            <p class="text-sm text-slate-600 dark:text-slate-300">Discord bots and scripts</p>
          </div>
        </div>
        <div class="flex items-start gap-3">
          <span class="text-2xl">📱</span>
          <div>
            <h3 class="font-semibold text-slate-900 dark:text-white">Mobile Projects</h3>
            <p class="text-sm text-slate-600 dark:text-slate-300">Responsive mobile-first apps</p>
          </div>
        </div>
        <div class="flex items-start gap-3">
          <span class="text-2xl">🔧</span>
          <div>
            <h3 class="font-semibold text-slate-900 dark:text-white">Developer Tools</h3>
            <p class="text-sm text-slate-600 dark:text-slate-300">CLI tools and utilities</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Suggest Workshop CTA -->
  <section>
    <div class="card text-center">
      <h2 class="text-2xl font-bold text-slate-900 dark:text-white">Have a workshop idea?</h2>
      <p class="mt-3 text-slate-600 dark:text-slate-300">
        Want to lead a workshop or suggest a topic for the club to explore? 
        We're always open to new ideas and collaborative sessions.
      </p>
      <div class="mt-6">
        <a class="btn cta" href="/contact">Suggest a workshop</a>
      </div>
    </div>
  </section>
</BaseLayout>

