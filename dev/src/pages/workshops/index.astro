---
import { getCollection } from 'astro:content';
import { Icon } from 'astro-icon/components';
import BaseLayout from '../../layouts/BaseLayout.astro';

const workshops = (await getCollection('workshops')).sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
---

<BaseLayout
  title="Workshops | Gharbiya STEM Hack Club"
  description="Hack Club workshops and practical learning sessions delivered by the club."
  currentPath="/workshops"
>
  <section class="mb-8">
    <h1 class="text-3xl font-bold text-slate-900 dark:text-white">Workshops</h1>
    <p class="mt-2 text-slate-600 dark:text-slate-300">
      We actively join Hack Club workshops and transform those sessions into practical project outcomes.
    </p>
  </section>
  <div class="grid gap-6 md:grid-cols-2">
    {
      workshops.map(({ id, data, body }) => (
        <article class="surface">
          <p class="text-xs uppercase tracking-wide text-slate-500 dark:text-slate-400">{data.date.toLocaleDateString('en-GB')} · {data.provider}</p>
          <h2 class="mt-2 text-xl font-semibold text-slate-900 dark:text-white">{data.title}</h2>
          <p class="mt-3 text-sm text-slate-600 dark:text-slate-300">{body}</p>
          <p class="mt-4 text-sm font-medium text-slate-700 dark:text-slate-200">{data.outcome}</p>
          {
            (data.approvedSubmissions || data.participations || data.budgetSpent) && (
              <div class="mt-3 space-y-1 text-xs text-slate-600 dark:text-slate-400">
                {data.approvedSubmissions && <p class="flex items-center gap-1.5"><Icon name="mdi:check-circle" class="w-4 h-4 flex-shrink-0" /> {data.approvedSubmissions} approved submissions</p>}
                {data.participations && <p class="flex items-center gap-1.5"><Icon name="mdi:check-circle" class="w-4 h-4 flex-shrink-0" /> {data.participations}+ participations</p>}
                {data.budgetSpent && <p class="flex items-center gap-1.5"><Icon name="mdi:wallet-outline" class="w-4 h-4 flex-shrink-0" /> {data.budgetSpent}</p>}
                {data.rewardsMarketing && <p class="flex items-center gap-1.5"><Icon name="mdi:gift" class="w-4 h-4 flex-shrink-0" /> {data.rewardsMarketing}</p>}
                {data.note && <p>{data.note}</p>}
              </div>
            )
          }
          <div class="mt-4 flex flex-wrap items-center gap-4">
            <a class="inline-flex text-sm font-semibold text-[#ec3750] hover:text-[#d63447] dark:text-[#ff8c37] dark:hover:text-[#ff8c37]/80" href={`/workshops/${id.replace(/\.md$/, '')}/`}>
              Read details
            </a>
            {
              data.links && data.links.length > 0 && (
                <>
                  {data.links.map((link) => (
                    <a class="inline-flex text-sm font-semibold text-[#ec3750] hover:text-[#d63447] dark:text-[#ff8c37] dark:hover:text-[#ff8c37]/80" href={link.url} target="_blank" rel="noreferrer">
                      {link.label}
                    </a>
                  ))}
                </>
              )
            }
          </div>
        </article>
      ))
    }
  </div>
</BaseLayout>

