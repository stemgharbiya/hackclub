---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import EventCards from '../../components/EventCards.astro';

const events = (await getCollection('events')).sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
const upcomingEvents = events.filter(e => e.data.date > new Date());
const pastEvents = events.filter(e => e.data.date <= new Date());
---

<BaseLayout
  title="Events | Gharbiya STEM Hack Club"
  description="Track season events and outcomes by Gharbiya STEM Hack Club."
  currentPath="/events"
>
  <!-- Hero Section -->
  <section class="surface mb-12">
    <p class="text-sm font-semibold uppercase tracking-wide" style="color: var(--color-green)">// ALWAYS BUILDING</p>
    <h1 class="mt-3 text-4xl font-bold tracking-tight text-slate-900 dark:text-white sm:text-5xl">Something's always happening.</h1>
    <p class="mt-4 max-w-3xl text-lg text-slate-600 dark:text-slate-300">
      From kickoff celebrations to workshop fairs, our events bring the community together to learn, 
      build, and share. Season 5 has already delivered two successful events with strong participation and outcomes.
    </p>
    <div class="mt-6 flex flex-wrap gap-3">
      <a class="btn-primary" href="https://www.instagram.com/gh_hackclub/" target="_blank" rel="noreferrer">Follow for updates</a>
      <a class="btn-secondary" href="#past-events">View past events</a>
    </div>
  </section>

  <!-- Upcoming Events -->
  {upcomingEvents.length > 0 && (
    <section class="mb-12">
      <h2 class="mb-6 text-3xl font-bold text-slate-900 dark:text-white">Upcoming Events</h2>
      <EventCards events={upcomingEvents} />
    </section>
  )}

  <!-- Past Events Gallery -->
  <section class="mb-12" id="past-events">
    <h2 class="mb-6 text-3xl font-bold text-slate-900 dark:text-white">Past Events</h2>
    <EventCards events={pastEvents} />
  </section>

  <!-- Event Stats / Impact -->
  <section class="mb-12">
    <h2 class="mb-6 text-3xl font-bold text-slate-900 dark:text-white">Season 5 Impact</h2>
    <div class="grid gap-6 sm:grid-cols-3">
      <div class="surface text-center">
        <p class="text-4xl font-bold" style="color: var(--accent)">{events.length}</p>
        <p class="mt-2 text-sm text-slate-600 dark:text-slate-300">Events Delivered</p>
      </div>
      <div class="surface text-center">
        <p class="text-4xl font-bold" style="color: var(--color-green)">100+</p>
        <p class="mt-2 text-sm text-slate-600 dark:text-slate-300">Total Participants</p>
      </div>
      <div class="surface text-center">
        <p class="text-4xl font-bold" style="color: var(--color-blue)">Level 3</p>
        <p class="mt-2 text-sm text-slate-600 dark:text-slate-300">Achievement Tier</p>
      </div>
    </div>
  </section>

  <!-- Hackathons / Special Events -->
  <section class="mb-12">
    <div class="surface">
      <h2 class="text-2xl font-bold text-slate-900 dark:text-white">Planning a Hackathon?</h2>
      <p class="mt-3 text-slate-600 dark:text-slate-300">
        We're always looking to collaborate with other clubs and organizations. Whether you're hosting a hackathon, 
        running a workshop, or organizing a tech event, we'd love to partner up or participate.
      </p>
      <div class="mt-6">
        <a class="btn-secondary" href="/contact">Get in touch</a>
      </div>
    </div>
  </section>

  <!-- Newsletter / Follow CTA -->
  <section>
    <div class="surface text-center" style="background: linear-gradient(135deg, rgba(51, 214, 166, 0.1), rgba(51, 142, 218, 0.1));">
      <h2 class="text-2xl font-bold text-slate-900 dark:text-white">Never miss an event</h2>
      <p class="mt-3 text-slate-600 dark:text-slate-300">
        Follow us on Instagram to get the latest updates, event announcements, and registration links.
      </p>
      <div class="mt-6">
        <a class="btn-primary" href="https://www.instagram.com/gh_hackclub/" target="_blank" rel="noreferrer">
          Follow @gh_hackclub
        </a>
      </div>
    </div>
  </section>
</BaseLayout>

