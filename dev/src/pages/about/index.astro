---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import TeamGrid from '../../components/TeamGrid.astro';

const team = (await getCollection('team')).sort((a, b) => a.data.order - b.data.order);
---

<BaseLayout
  title="About | Gharbiya STEM Hack Club"
  description="Learn about Gharbiya STEM Hack Club mission, season progress, and impact."
  currentPath="/about"
>
  <!-- Hero Section -->
  <section class="surface mb-12">
    <p class="text-sm font-semibold uppercase tracking-wide" style="color: var(--color-blue)">// WHO WE ARE</p>
    <h1 class="mt-3 text-4xl font-bold tracking-tight text-slate-900 dark:text-white sm:text-5xl">Building the future, together.</h1>
    <p class="mt-4 max-w-3xl text-lg text-slate-600 dark:text-slate-300">
      Gharbiya STEM Hack Club is a student-led technology community focused on practical learning, collaboration, and maker culture.
      Our mission is to turn curiosity into shipped work through structured training tracks and high-energy events.
    </p>
    <div class="mt-6 flex flex-wrap gap-3">
      <a class="btn-primary" href="/bootcamps">Explore bootcamps</a>
      <a class="btn-secondary" href="/contact">Get in touch</a>
    </div>
  </section>

  <!-- Our Story Section -->
  <section class="mb-12">
    <h2 class="mb-6 text-3xl font-bold text-slate-900 dark:text-white">Our Story</h2>
    <div class="grid gap-8 md:grid-cols-2">
      <div class="surface">
        <h3 class="text-xl font-semibold text-slate-900 dark:text-white">The Beginning</h3>
        <p class="mt-3 text-sm text-slate-600 dark:text-slate-300">
          Founded by passionate students at Gharbiya STEM School, our Hack Club chapter emerged from a shared vision: 
          create a space where curiosity meets action, where learning happens by building, and where every student 
          can become a maker.
        </p>
      </div>
      <div class="surface">
        <h3 class="text-xl font-semibold text-slate-900 dark:text-white">Season 5 Progress</h3>
        <p class="mt-3 text-sm text-slate-600 dark:text-slate-300">
          We're currently at <strong>Level 3 (MAX)</strong> — the highest achievement tier. 
          With two successful events already delivered and four major bootcamps running from February to June, 
          we're building momentum and shipping real projects.
        </p>
      </div>
    </div>
  </section>

  <!-- Values Section -->
  <section class="mb-12">
    <h2 class="mb-6 text-3xl font-bold text-slate-900 dark:text-white">Our Values</h2>
    <div class="grid gap-6 md:grid-cols-3">
      <div class="surface">
        <div class="mb-3 inline-flex rounded-lg p-3" style="background: var(--color-red); opacity: 0.1;">
          <span class="text-2xl">🚀</span>
        </div>
        <h3 class="text-lg font-semibold text-slate-900 dark:text-white">Learn by Doing</h3>
        <p class="mt-2 text-sm text-slate-600 dark:text-slate-300">
          Theory is great, but we believe in hands-on building. Every workshop, every bootcamp is designed 
          around creating real projects you can show off.
        </p>
      </div>
      <div class="surface">
        <div class="mb-3 inline-flex rounded-lg p-3" style="background: var(--color-green); opacity: 0.1;">
          <span class="text-2xl">🤝</span>
        </div>
        <h3 class="text-lg font-semibold text-slate-900 dark:text-white">Community First</h3>
        <p class="mt-2 text-sm text-slate-600 dark:text-slate-300">
          We're stronger together. Our club thrives on collaboration, peer learning, and helping each other 
          grow as makers and problem solvers.
        </p>
      </div>
      <div class="surface">
        <div class="mb-3 inline-flex rounded-lg p-3" style="background: var(--color-blue); opacity: 0.1;">
          <span class="text-2xl">💡</span>
        </div>
        <h3 class="text-lg font-semibold text-slate-900 dark:text-white">Ship It</h3>
        <p class="mt-2 text-sm text-slate-600 dark:text-slate-300">
          Ideas are just the start. We focus on execution, iteration, and sharing our work with the world. 
          Done is better than perfect.
        </p>
      </div>
    </div>
  </section>

  <!-- Team Section -->
  <section class="mb-12">
    <h2 class="mb-6 text-3xl font-bold text-slate-900 dark:text-white">Meet the Team</h2>
    <TeamGrid team={team} />
    <div class="mt-6 text-center">
      <a href="/team" class="btn-secondary">View full team →</a>
    </div>
  </section>

  <!-- Stats Section -->
  <section class="mb-12">
    <h2 class="mb-6 text-3xl font-bold text-slate-900 dark:text-white">By the Numbers</h2>
    <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
      <div class="surface text-center">
        <p class="text-4xl font-bold" style="color: var(--accent)">4</p>
        <p class="mt-2 text-sm text-slate-600 dark:text-slate-300">Major Bootcamps</p>
      </div>
      <div class="surface text-center">
        <p class="text-4xl font-bold" style="color: var(--color-orange)">2</p>
        <p class="mt-2 text-sm text-slate-600 dark:text-slate-300">Events Delivered</p>
      </div>
      <div class="surface text-center">
        <p class="text-4xl font-bold" style="color: var(--color-green)">{team.length}</p>
        <p class="mt-2 text-sm text-slate-600 dark:text-slate-300">Team Members</p>
      </div>
      <div class="surface text-center">
        <p class="text-4xl font-bold" style="color: var(--color-blue)">5</p>
        <p class="mt-2 text-sm text-slate-600 dark:text-slate-300">Seasons Running</p>
      </div>
    </div>
  </section>

  <!-- Backed By Section -->
  <section class="mb-12">
    <div class="surface text-center">
      <h2 class="text-2xl font-bold text-slate-900 dark:text-white">Part of the Hack Club Network</h2>
      <p class="mt-3 text-slate-600 dark:text-slate-300">
        We're proud to be part of the global Hack Club community — a nonprofit network of high school 
        coding clubs and makers supported by leaders in tech.
      </p>
      <div class="mt-6">
        <a href="https://hackclub.com" target="_blank" rel="noreferrer" class="btn-ghost">
          Learn about Hack Club →
        </a>
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section>
    <div class="surface text-center" style="background: linear-gradient(135deg, rgba(236, 55, 80, 0.1), rgba(51, 214, 166, 0.1));">
      <h2 class="text-3xl font-bold text-slate-900 dark:text-white">Ready to join us?</h2>
      <p class="mt-3 text-slate-600 dark:text-slate-300">
        Follow our journey on Instagram and check out upcoming events.
      </p>
      <div class="mt-6 flex flex-wrap justify-center gap-3">
        <a class="btn-primary" href="https://www.instagram.com/gh_hackclub/" target="_blank" rel="noreferrer">Follow on Instagram</a>
        <a class="btn-secondary" href="/events">View events</a>
      </div>
    </div>
  </section>
</BaseLayout>

