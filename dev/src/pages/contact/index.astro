---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Contact | Gharbiya STEM Hack Club"
  description="Get in touch with Gharbiya STEM Hack Club and follow current activities."
  currentPath="/contact"
>
  <section class="surface max-w-2xl">
    <h1 class="text-3xl font-bold text-slate-900 dark:text-white">Contact & Links</h1>
    <p class="mt-3 text-slate-600 dark:text-slate-300">
      The best way to stay updated is through our social channels where we share announcements, event media, and registration updates.
    </p>

    <div class="mt-6 space-y-3 text-sm">
      <p>
        <span class="font-semibold text-slate-900 dark:text-white">GitHub:</span>
        <a class="ml-2 text-[#ec3750] hover:text-[#d63447] dark:text-[#ff8c37] dark:hover:text-[#ff8c37]/80" href="https://github.com/hack-club-gh" target="_blank" rel="noreferrer">https://github.com/hack-club-gh</a>
      </p>
      <p>
        <span class="font-semibold text-slate-900 dark:text-white">Instagram:</span>
        <a class="ml-2 text-[#ec3750] hover:text-[#d63447] dark:text-[#ff8c37] dark:hover:text-[#ff8c37]/80" href="https://www.instagram.com/gh_hackclub/" target="_blank" rel="noreferrer">https://www.instagram.com/gh_hackclub/</a>
      </p>
    </div>
  </section>
</BaseLayout>

