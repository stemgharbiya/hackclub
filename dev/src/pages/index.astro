---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import BootcampCards from '../components/BootcampCards.astro';
import EventCards from '../components/EventCards.astro';
import TeamGrid from '../components/TeamGrid.astro';
import FAQList from '../components/FAQList.astro';

const bootcamps = (await getCollection('bootcamps')).sort((a, b) => a.data.order - b.data.order);
const events = (await getCollection('events')).sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
const team = (await getCollection('team')).sort((a, b) => a.data.order - b.data.order);
const featuredTeam = team.filter((member) => member.data.featured).length > 0 ? team.filter((member) => member.data.featured) : team.slice(0, 4);
const faqs = (await getCollection('faqs')).sort((a, b) => a.data.order - b.data.order);
---

<BaseLayout
  title="Gharbiya STEM Hack Club"
  description="Official marketing site for Gharbiya STEM Hack Club activities, bootcamps, events, and team updates."
  currentPath="/"
>
  <section class="surface mb-10">
    <p class="text-sm font-semibold uppercase tracking-wide text-blue-600 dark:text-blue-400">Season 5 · Level 3 (MAX)</p>
    <h1 class="mt-3 text-4xl font-bold tracking-tight text-slate-900 dark:text-white sm:text-5xl">Gharbiya STEM Hack Club</h1>
    <p class="mt-4 max-w-3xl text-base text-slate-600 dark:text-slate-300">
      Building makers through high-impact bootcamps in Data Science, Web Development, Cyber Security, and Competitive Programming from February to June.
    </p>
    <div class="mt-6 flex flex-wrap gap-3">
      <a class="btn-primary" href="/bootcamps">Explore bootcamps</a>
      <a class="btn-secondary" href="https://www.instagram.com/gh_hackclub/" target="_blank" rel="noreferrer">See activity on Instagram</a>
    </div>
    <div class="mt-8 grid gap-4 sm:grid-cols-3">
      <div class="rounded-xl border border-slate-200 p-4 dark:border-slate-800">
        <p class="text-2xl font-bold text-slate-900 dark:text-white">4</p>
        <p class="text-sm text-slate-600 dark:text-slate-300">Major bootcamps</p>
      </div>
      <div class="rounded-xl border border-slate-200 p-4 dark:border-slate-800">
        <p class="text-2xl font-bold text-slate-900 dark:text-white">2</p>
        <p class="text-sm text-slate-600 dark:text-slate-300">Successful events so far</p>
      </div>
      <div class="rounded-xl border border-slate-200 p-4 dark:border-slate-800">
        <p class="text-2xl font-bold text-slate-900 dark:text-white">5th</p>
        <p class="text-sm text-slate-600 dark:text-slate-300">Current season</p>
      </div>
    </div>
  </section>

  <section class="mb-12">
    <div class="mb-5 flex items-end justify-between">
      <h2 class="text-2xl font-bold text-slate-900 dark:text-white">Bootcamps (Feb–Jun)</h2>
      <a href="/bootcamps" class="text-sm font-semibold text-[#ec3750] dark:text-[#ff8c37]">View all</a>
    </div>
    <BootcampCards bootcamps={bootcamps} />
  </section>

  <section class="mb-12">
    <div class="mb-5 flex items-end justify-between">
      <h2 class="text-2xl font-bold text-slate-900 dark:text-white">Recent Events</h2>
      <a href="/events" class="text-sm font-semibold text-[#ec3750] dark:text-[#ff8c37]">View all</a>
    </div>
    <EventCards events={events.slice(0, 2)} />
  </section>

  <section class="mb-12">
    <div class="mb-5 flex items-end justify-between">
      <h2 class="text-2xl font-bold text-slate-900 dark:text-white">Team</h2>
      <a href="/team" class="text-sm font-semibold text-[#ec3750] dark:text-[#ff8c37]">Meet everyone</a>
    </div>
    <TeamGrid team={featuredTeam} />
  </section>

  <section>
    <h2 class="mb-5 text-2xl font-bold text-slate-900 dark:text-white">FAQs</h2>
    <FAQList faqs={faqs} />
  </section>
</BaseLayout>
